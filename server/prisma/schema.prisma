generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Packages ─────────────────────────────────────────────────────────

model Package {
  id                     String   @id @default(cuid())
  name                   String
  // Desktop User price = Microsoft 365 Business Premium tier. The headline
  // per-user number customers see on the package card.
  pricePerUser           Float
  // Web User price = Microsoft 365 F3 (Web & Email Only) tier. Surfaced on
  // the customer wizard as "Web User"; admin-editable per package.
  pricePerUserF3         Float    @default(0)
  pricePerLocation       Float
  frequency              String   @default("monthly") // monthly | annually | one-time
  features               Json     @default("[]")       // string[] (legacy flat list)
  // Structured feature catalog used by the UI + contract PDF:
  // [{ category: 'Support', items: ['8x5 Support', 'Helpdesk Button…', …] }, …]
  // The flat `features` array is kept for backwards-compat with snapshotted
  // quotes; new code prefers featureGroups when present.
  featureGroups          Json     @default("[]")
  isBestValue            Boolean  @default(false)
  sortOrder              Int      @default(0)
  active                 Boolean  @default(true)
  // Admin toggle. When false the package row stays in DB and historical
  // quotes referencing it keep working, but /api/config filters it out so
  // customers can't pick it. Used to hide Essentials from public pricing.
  customerVisible        Boolean  @default(true)
  cwAgreementTypeId      Int?     // CW agreement type to use when this package is sold
  // CW catalog product IDs for the per-package recurring lines. postAdditions
  // posts one Addition per row that's set: per-user (Desktop / Business
  // Premium) × desktop count, per-user F3 (Web User) × web count,
  // per-location × locationCount.
  cwPerUserProductId     Int?
  cwPerUserF3ProductId   Int?
  cwPerLocationProductId Int?
  agreementMonths        Int      @default(0) // 0 = month-to-month; 36 = 3-year; 60 = 5-year
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("packages")
}

// ── Editable site copy ───────────────────────────────────────────────
// Singleton row (id="default"). Admins edit customer-facing copy here so
// marketing wording doesn't require a code deploy. Loaded by /api/config and
// rendered on the customer wizard.

model SiteContent {
  id                            String   @id @default("default")
  quoteBuilderHeading           String   @default("Choose Your Package")
  quoteBuilderSubheading        String   @default("Pick the plan that fits. We'll size the quote to your team on the next step.")
  quoteBuilderExplainerTitle    String   @default("Desktop User vs Web User")
  quoteBuilderExplainerBody     String   @default("Desktop User — full Microsoft 365 Business Premium. Use this for your primary staff who need the full desktop apps, Teams calls, and offline access.\n\nWeb User — Microsoft 365 F3 (Web & Email Only). Use this for frontline, warehouse, kiosk, or shared-device employees who only need email and browser-based apps. Costs less per user.")
  updatedAt                     DateTime @updatedAt

  @@map("site_content")
}

// ── Addons ───────────────────────────────────────────────────────────

model Addon {
  id                 String   @id @default(cuid())
  name               String
  description        String
  price              Float
  frequency          String   @default("monthly")
  active             Boolean  @default(true)
  recurringPrice     Float?
  recurringFrequency String?
  setupPrice         Float?
  pricingType        String   @default("recurring-only") // recurring-only | one-time-only | both
  sortOrder          Int      @default(0)
  cwProductId        Int?     // CW catalog product id, required by Addition.product on POST
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("addons")
}

// ── Promo Codes ──────────────────────────────────────────────────────

model PromoCode {
  id           String   @id @default(cuid())
  code         String   @unique
  discount     Float
  discountType String   // percentage | fixed
  applyTo      String   // one-time | monthly | onboarding
  active       Boolean  @default(true)
  maxUses      Int?
  currentUses  Int      @default(0)
  expiresAt    DateTime?
  // Hidden from the customer wizard + /api/promo-codes/validate. Admin can
  // still apply it to a quote from /admin/quotes/:id. Used for things like
  // the 5-year discount that NTM sales applies on case-by-case basis.
  adminOnly    Boolean  @default(false)
  // Optional CW catalog product id (e.g. PERUSER0004-MRR for the 5-year
  // discount). When set, postAdditions posts a negative-priced Addition for
  // the discount amount onto the CW agreement so CW invoices match the
  // discounted total. When null, the discount only affects the quote totals
  // and AP first-month invoice; CW invoices the full per-unit prices.
  cwProductId  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("promo_codes")
}

// ── Terms ────────────────────────────────────────────────────────────

model Terms {
  id          String   @id @default(cuid())
  version     String   @unique
  content     String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("terms")
}

// ── Quotes ───────────────────────────────────────────────────────────

model Quote {
  id                 String    @id @default(cuid())
  quoteNumber        String    @unique
  status             String    @default("draft") // draft | sent | accepted | checkout_pending | paid | expired
  customer           Json      // CustomerInfo snapshot
  selectedPackage    Json      // QuoteSelectedPackage snapshot
  selectedAddons     Json      // QuoteSelectedAddon[] snapshot
  onboarding         Json      // QuoteOnboarding snapshot
  appliedPromoCodes  Json      @default("[]") // AppliedPromoCode[] snapshot
  totals             Json      // QuoteTotals snapshot
  terms              Json      // { version, id, url, content } snapshot
  agreement          Json?     // QuoteAgreement (filled on acceptance)
  orderNumber        String?   @unique

  // Custom line items added by NTM staff after the customer built the quote.
  // Shape: [{ id, name, description, quantity, recurringPrice?, oneTimePrice?, addedBy?, addedAt }]
  customItems        Json     @default("[]")

  // Alternative Payments
  apCustomerId       String?
  apInvoiceId        String?
  apPaymentLink      String?

  // ConnectWise
  cwCompanyId        Int?
  cwContactId        Int?
  cwOpportunityId    Int?
  cwProjectId        Int?
  cwAgreementId      Int?

  // GoHighLevel
  ghlContactId       String?
  ghlOpportunityId   String?

  // Amendment linkage. When an admin edits an already-paid quote we leave
  // the original alone and create a new quote with parentQuoteId pointing
  // back at it. The amendment carries its own AP invoice for the delta.
  parentQuoteId      String?
  parent             Quote?   @relation("QuoteAmendments", fields: [parentQuoteId], references: [id])
  amendments         Quote[]  @relation("QuoteAmendments")

  // Free-text notes — admin-edited, customer-visible. Used to capture
  // anything the structured fields don't cover (custom scope, special
  // pricing rationale, hand-off instructions, etc.).
  notes              String?

  // Provisioning state (populated by the CW step machine).
  // pending = nothing started; provisioned = all required steps ok;
  // partial = some non-critical step failed and was logged for retry;
  // failed = a hard-fail step (company creation) threw and webhook returned 500.
  provisioningStatus String  @default("pending")

  expiresAt          DateTime?
  // Set when the 30-day follow-up email goes out. Stays null until then so
  // the worker can find unpaid quotes that still need a nudge. Once stamped
  // the worker leaves it alone — we only nudge once per quote.
  followupSentAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  contracts          Contract[]
  provisioningSteps  CwProvisioningStep[]

  @@index([status])
  @@index([createdAt])
  @@index([provisioningStatus])
  @@index([parentQuoteId])
  @@index([followupSentAt])
  @@map("quotes")
}

// ── CW Provisioning Steps ────────────────────────────────────────────
// One row per (quoteId, step). Used by the step machine in connectwise.service.ts
// to make orchestration idempotent and resumable. The @@unique constraint is
// the load-bearing part: concurrent retries upsert against the same row instead
// of creating duplicates.

model CwProvisioningStep {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  step      String   // company | site | contact | billingContact | opportunity | agreement | additions | activate | project | crossref | handoff
  status    String   // pending | success | failed | skipped
  cwId      Int?     // CW-side id this step produced (company id, contact id, etc.)
  attempts  Int      @default(0)
  lastError String?
  startedAt DateTime?
  updatedAt DateTime @updatedAt

  @@unique([quoteId, step])
  @@index([status])
  @@map("cw_provisioning_steps")
}

// ── Contracts ────────────────────────────────────────────────────────

model Contract {
  id         String   @id @default(cuid())
  quoteId    String
  quote      Quote    @relation(fields: [quoteId], references: [id])
  pdfUrl     String?
  pdfData    Bytes?
  emailedAt  DateTime?
  createdAt  DateTime @default(now())

  @@map("contracts")
}

// ── Admin Users ──────────────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

// ── Integration Credentials ──────────────────────────────────────────
// Editable from /admin/integrations. Loaded into a synchronous cache on
// process start (see integration-credentials.service.ts). DB values
// override matching env vars at runtime, so the same Railway service
// can be reconfigured without redeploys.

model IntegrationCredential {
  key       String   @id   // matches the env-var name, e.g. "CW_PUBLIC_KEY"
  value     String
  notes     String?
  updatedAt DateTime @updatedAt

  @@map("integration_credentials")
}

// ── ConnectWise Reference Config ─────────────────────────────────────
// Key/value store for CW reference IDs (agreement-type defaults, project type/board/template,
// member ids, tax codes, custom field ids, etc.). Lookups are documented in docs/cw-reference-ids.md.
// Loaded into in-memory cache by cw-config.service.ts.

model CwConfig {
  key       String   @id
  value     String   // stored as string, numeric values parsed by the loader
  notes     String?  // optional human note ("Project board for Onboarding")
  updatedAt DateTime @updatedAt

  @@map("cw_config")
}

// ── AI Chat ──────────────────────────────────────────────────────────
// Singleton-style config (always row id="default"). Loaded into a cache by
// ai-config.service.ts the same way integration credentials are. The admin
// UI at /admin/ai-chat edits this row; changes apply on the next request.

model AiAgentConfig {
  id                  String   @id @default("default")
  enabled             Boolean  @default(false)
  primaryModel        String   @default("anthropic/claude-sonnet-4-5")
  fallbackModel       String   @default("openai/gpt-4o-mini")
  temperature         Float    @default(0.3)
  maxTokens           Int      @default(1024)
  requestTimeoutMs    Int      @default(30000)
  systemPrompt        String   @default("")
  greeting            String   @default("Hi! 👋 I'm here to help you build your quote — I can answer questions, recommend a package, and even fill out fields for you. What can I help you with first?")
  disclaimer          String   @default("AI assistant — may make mistakes. You make the final decisions.")
  perSessionUsdCap    Float    @default(10)
  dailyUsdCap         Float    @default(50)
  idleTimeoutMs       Int      @default(1800000)   // 30 min
  absoluteTimeoutMs   Int      @default(14400000)  // 4 hr
  ratePerMin          Int      @default(20)        // messages/min/session
  // Tool allowlist — comma-separated names. UI tools only; no DB-write tools.
  // Defaults: highlight_field, prefill_field, navigate, suggest_addon, suggest_package.
  allowedTools        String   @default("highlight_field,prefill_field,navigate,suggest_addon,suggest_package,request_followup")
  updatedAt           DateTime @updatedAt

  @@map("ai_agent_config")
}

// Admin-curated knowledge-base documents. Plain markdown; the chat service
// concatenates active docs (sorted) into the system prompt context.
model AiKnowledgeBase {
  id        String   @id @default(cuid())
  title     String
  content   String   // markdown
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
  @@map("ai_kb")
}

// One row per chat conversation. The cookie value is the session id (signed).
// `usdSpent` is the running per-session cost; once it reaches the per-session
// cap the server refuses further messages.
model ChatSession {
  id              String        @id @default(cuid())
  status          String        @default("active") // active | ended | expired | capped
  quoteId         String?       // linked once the customer creates a quote
  ipAddress       String?
  userAgent       String?
  usdSpent        Float         @default(0)
  tokensIn        Int           @default(0)
  tokensOut       Int           @default(0)
  usingFallback   Boolean       @default(false)
  meta            Json          @default("{}")
  lastActivityAt  DateTime      @default(now())
  createdAt       DateTime      @default(now())
  endedAt         DateTime?
  messages        ChatMessage[]

  @@index([status])
  @@index([createdAt])
  @@map("chat_sessions")
}

// Messages stored AFTER PII redaction. `role` is OpenAI-style. Tool calls
// produced by the model are stored on the assistant row that emitted them;
// the corresponding tool result is its own row with role="tool".
model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String      // user | assistant | system | tool
  content    String
  toolCalls  Json?       // assistant tool-call payload (if any)
  toolName   String?     // for role="tool" rows
  model      String?
  tokensIn   Int?
  tokensOut  Int?
  usdCost    Float       @default(0)
  fallback   Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

// ── Audit Logs ───────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  data      Json?
  adminId   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
